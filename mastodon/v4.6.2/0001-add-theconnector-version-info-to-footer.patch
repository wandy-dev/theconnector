diff --git a/lib/theconnector/version.rb b/lib/theconnector/version.rb
new file mode 100644
index 000000000..e8efb7991
--- /dev/null
+++ b/lib/theconnector/version.rb
@@ -0,0 +1,28 @@
+# frozen_string_literal: true
+
+module Theconnector
+  module Version
+    module_function
+
+    def major
+      0
+    end
+
+    def minor
+      1
+    end
+
+    def patch
+      0
+    end
+
+    def to_a
+      [major, minor, patch].compact
+    end
+
+    def to_s
+      components = [to_a.join('.')]
+      components.join
+    end
+  end
+end
