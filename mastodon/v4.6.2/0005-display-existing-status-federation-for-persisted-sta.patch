 app/serializers/rest/status_serializer.rb     |  6 +++++-
 5 files changed, 29 insertions(+), 5 deletions(-)

diff --git a/app/javascript/mastodon/api_types/statuses.ts b/app/javascript/mastodon/api_types/statuses.ts
index d61d8ceed..77b937fd1 100644
--- a/app/javascript/mastodon/api_types/statuses.ts
+++ b/app/javascript/mastodon/api_types/statuses.ts
@@ -14,6 +14,8 @@ export type StatusVisibility =
   // | 'limited' // This is never exposed to the API (they become `private`)
   | 'direct';
 
+export type StatusFederation = 'full' | 'limited';
+
 export interface ApiStatusApplicationJSON {
   name: string;
   website: string;
@@ -97,6 +99,7 @@ export interface ApiStatusJSON {
   favorites_count: number;
   quotes_count: number;
   edited_at?: string;
+  federation: StatusFederation;
 
   favorited?: boolean;
   reblogged?: boolean;
diff --git a/app/javascript/mastodon/features/ui/components/visibility_modal.tsx b/app/javascript/mastodon/features/ui/components/visibility_modal.tsx
index 9e5d54d3b..12031b01c 100644
--- a/app/javascript/mastodon/features/ui/components/visibility_modal.tsx
+++ b/app/javascript/mastodon/features/ui/components/visibility_modal.tsx
@@ -102,9 +102,22 @@ const selectStatusPolicy = createAppSelector(
 );
 
 const selectFederationPolicy = createAppSelector(
-  [(state) => state.compose.get('federation_policy') as ApiFederationPolicy],
-  (composeFederationPolicy) => {
-    return composeFederationPolicy;
+  [
+    (state) => state.statuses,
+    (_state, statusId?: string) => statusId,
+    (state) => state.compose.get('federation_policy') as ApiFederationPolicy,
+  ],
+  (statuses, statusId, composeFederationPolicy) => {
+    if (!statusId) return composeFederationPolicy;
+    const status = statuses.get(statusId);
+    if (!status) {
+      return 'full';
+    }
+    const policy = status.get('federation') as ApiFederationPolicy;
+    if (isFederationPolicy(policy)) {
+      return policy;
+    }
+    return 'full';
   },
 );
 
@@ -141,7 +154,7 @@ export const VisibilityModal: FC<VisibilityModalProps> = forwardRef(
       selectStatusPolicy(state, statusId),
     );
     const currentFederationPolicy = useAppSelector((state) =>
-      selectFederationPolicy(state),
+      selectFederationPolicy(state, statusId),
     );
 
     const [visibility, setVisibility] = useState(currentVisibility);
