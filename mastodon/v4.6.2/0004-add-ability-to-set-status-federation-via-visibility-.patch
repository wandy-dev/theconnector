index 000000000..e91a6fda0
--- /dev/null
+++ b/app/javascript/mastodon/api_types/federation.ts
@@ -0,0 +1,12 @@
+export type ApiFederationPolicy = 'full' | 'limited' | 'unsupported_policy';
+
+export interface ApiFederationPolicyJSON {
+  automatic: ApiFederationPolicy[];
+  manual: ApiFederationPolicy[];
+}
+
+export function isFederationPolicy(
+  policy: string,
+): policy is ApiFederationPolicy {
+  return ['full', 'limited'].includes(policy);
+}
