diff --git a/app/javascript/mastodon/components/federation_icon.tsx b/app/javascript/mastodon/components/federation_icon.tsx
new file mode 100644
index 000000000..01668a35c
--- /dev/null
+++ b/app/javascript/mastodon/components/federation_icon.tsx
@@ -0,0 +1,44 @@
+import { defineMessages, useIntl } from 'react-intl';
+
+import LockIcon from '@/material-icons/400-24px/lock.svg?react';
+import PublicIcon from '@/material-icons/400-24px/public.svg?react';
+import type { StatusFederation } from 'mastodon/models/status';
+
+import { Icon } from './icon';
+
+const messages = defineMessages({
+  full_short: { id: 'federation.full.short', defaultMessage: 'Full' },
+  limited_short: {
+    id: 'federation.limited.short',
+    defaultMessage: 'Instance Only',
+  },
+});
+
+export const FederationIcon: React.FC<{ federation: StatusFederation }> = ({
+  federation,
+}) => {
+  const intl = useIntl();
+
+  const federationIconInfo = {
+    full: {
+      icon: 'globe',
+      iconComponent: PublicIcon,
+      text: intl.formatMessage(messages.full_short),
+    },
+    limited: {
+      icon: 'lock',
+      iconComponent: LockIcon,
+      text: intl.formatMessage(messages.limited_short),
+    },
+  };
+
+  const federationIcon = federationIconInfo[federation];
+
+  return (
+    <Icon
+      id={federationIcon.icon}
+      icon={federationIcon.iconComponent}
+      aria-label={federationIcon.text}
+    />
+  );
+};
