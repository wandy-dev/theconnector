+export const StatusFederation: FC<{ federation: unknown }> = ({
+  federation,
+}) => {
+  if (typeof federation !== 'string' || !isStatusFederation(federation)) {
+    return null;
+  }
+  return (
+    <span className='status__visibility-icon'>
+      <FederationIcon federation={federation} />
+    </span>
+  );
+};
